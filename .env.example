# Copy to .env.local and fill values
VITE_APP_NAME="Eclipse Con"
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,es
VITE_DEBUG=false
VITE_APP_VERSION="2291"
VITE_ANALYTICS_ENABLED=false
# VITE_ANALYTICS_ENDPOINT=https://your-endpoint.example.com
# VITE_CF_WEB_ANALYTICS_TOKEN=your_cloudflare_web_analytics_token
# VITE_POSTHOG_API_KEY=your_posthog_api_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Telegram export (used by pnpm fetch:telegram)
# TELEGRAM_API_ID=123456
# TELEGRAM_API_HASH=your_api_hash
# TELEGRAM_PHONE=+123456789
# TELEGRAM_TARGET=t.me/FurrySunfest
# TELEGRAM_SINCE=2025-11-08 19:00

# Telegram translation provider (used by pnpm translate:telegram)
# TRANSLATE_PROVIDER=azure
# TRANSLATE_TO=en
#
# Azure AI Translator (recommended)
# AZURE_TRANSLATOR_KEY=your_azure_translator_key
# AZURE_TRANSLATOR_REGION=your_resource_region
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
# AZURE_TRANSLATOR_FROM=es
# If OPENAI_API_KEY is set while provider=azure, script auto-falls back to OpenAI per message.
#
# Optional: OpenAI fallback provider
# TRANSLATE_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
